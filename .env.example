# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
AGR_JWT_SECRET=<jwt-secret>

# Site URL — used for magic-link emailRedirectTo (must match Supabase Auth → Site URL)
# Production: https://agr-hmi-cloud.vercel.app
# Local dev:  http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://agr-hmi-cloud.vercel.app

# Cloudflare R2
R2_ACCOUNT_ID=<cf-account-id>
R2_ACCESS_KEY_ID=<r2-access-key>
R2_SECRET_ACCESS_KEY=<r2-secret-key>
R2_BUCKET_NAME=agr-ota

# Resend
RESEND_API_KEY=<resend-api-key>
RESEND_FROM_EMAIL=noreply@yourdomain.com
